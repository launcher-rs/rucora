# AgentKit 深度研究助手 - 环境变量示例
# 复制此文件为 .env 并填入你的配置

# ===== Provider 配置（选择一种）=====

# OpenAI
PROVIDER=OpenAI
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
# PROVIDER=Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini
# PROVIDER=Google Gemini
# GOOGLE_API_KEY=your-api-key-here
# GOOGLE_DEFAULT_MODEL=gemini-1.5-pro
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# NVIDIA DGX Cloud
# PROVIDER=NVIDIA (DGX Cloud)
# NVIDIA_API_KEY=nvapi-your-api-key-here
# NVIDIA_DEFAULT_MODEL=nvidia/nemotron-4-340b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Ollama (本地)
# PROVIDER=Ollama (本地)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_DEFAULT_MODEL=qwen3.5:9b

# ===== 通用配置（可选）=====
# 这些配置会覆盖 Provider 特定的配置

# API_KEY=your-api-key-here
# MODEL=your-model-name
# BASE_URL=https://api.example.com/v1

# ===== SerpAPI 配置（可选）=====
# 用于增强网络搜索功能

# SERPAPI_API_KEYS=key1,key2,key3
# SERPAPI_API_KEY=single-key
